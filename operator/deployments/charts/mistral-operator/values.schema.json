        "mistralCustomApiParams": {
            "type": "string"
        },
        "mistralCustomEngineParams": {
            "type": "string"
        },
        "mistralCustomExecutorParams": {
            "type": "string"
        },
        "mistralCustomNotifierParams": {
            "type": "string"
        },
