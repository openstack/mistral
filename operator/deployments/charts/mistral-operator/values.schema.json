                "args": {
                    "type": "string"
                },
                "securityContext": {
                    "type": "object"
                },
                "priorityClassName": {
                    "type": "string"
                }
            }
        },
        "mistralCleanupDbPod": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "memoryLimit": {
                    "type": "string"
