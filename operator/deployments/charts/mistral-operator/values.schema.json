                },
                "mistralExecutor": {
                    "$ref": "#/definitions/labelObject"
                },
                "mistralNotifier": {
                    "$ref": "#/definitions/labelObject"
                },
                "mistralMonitoring": {
                    "$ref": "#/definitions/labelObject"
                },
