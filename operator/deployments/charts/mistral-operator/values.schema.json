                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "$ref": "#/definitions/booleanOrString"
                        },
                        "secretName": {
                            "type": "string"
                        },
                        "certificates": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "ca": {
                                    "type": "string"
                                },
                                "crt": {
                                    "type": "string"
                                },
                                "key": {
                                    "type": "string"
                                }
                            }
                        },
                        "generateCerts": {
                            "type": "object",
                            "additionalProperties": false,
