                                    "additionalProperties": false
                                },
                                "postgres": {
                                    "type": "object",
                                    "properties": {
                                        "sslmode": {
                                            "type": "string"
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "rabbitmq": {
                                    "type": "object",
                                    "properties": {
                                        "enabled": {
                                            "$ref": "#/definitions/booleanOrString"
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "kafka": {
                                    "type": "object",
                                    "properties": {
                                        "enabled": {
                                            "$ref": "#/definitions/booleanOrString"
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "bluegreen": {
                                    "type": "object",
                                    "properties": {
                                        "enabled": {
                                            "$ref": "#/definitions/booleanOrString"
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "disasterRecovery": {
                                    "type": "object",
                                    "properties": {
                                        "enabled": {
                                            "$ref": "#/definitions/booleanOrString"
                                        }
                                    },
                                    "additionalProperties": false
                                }
                            }
                        },
                        "subjectAlternativeName": {
