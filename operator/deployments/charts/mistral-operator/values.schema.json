                        "idleTimeout": {
                            "type": "string"
                        }
                    }
                },
                "kafkaNotifications": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "$ref": "#/definitions/booleanOrString"
