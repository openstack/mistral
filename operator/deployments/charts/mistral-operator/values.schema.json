                                    "type": {
                                        "type": "string",
                                        "enum": ["extract", "map"]
                                    },
                                    "field": {
                                        "type": "string"
                                    },
                                    "pattern": {
                                        "type": "string"
                                    },
                                    "value": {
                                        "type": "string"
                                    },
                                    "project": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
