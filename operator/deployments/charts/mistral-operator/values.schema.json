            "$ref": "#/definitions/booleanOrString"
        },
        "HPA_MIN_REPLICAS": {
            "type": "integer"
        },
        "HPA_MAX_REPLICAS": {
            "type": "integer"
        },
        "HPA_AVG_CPU_UTILIZATION": {
            "type": "integer"
        },
        "HPA_SCALING_UP_PERCENT": {
            "type": "integer"
