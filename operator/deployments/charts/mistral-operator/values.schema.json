    "GatewayAPI": {
        "type": "object",
        "description": "Optional manual Gateway API overrides.",
        "properties": {
            "gatewayName": {
                "type": "string",
                "description": "Optional manual Gateway name override.",
                "default": "default-external-gateway"
            },
            "gatewayNamespace": {
                "type": "string",
                "description": "Optional manual Gateway namespace override.",
                "default": "gateway-system"
            }
        }
    },
    "required": [
        "name",
        "operatorImage",
        "mistral"
    ],
    "definitions": {
        "resources": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "requests": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "cpu": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "limits": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "cpu": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "labelObject": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string"
                },
                "component": {
                    "type": "string"
                },
                "instance": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                },
                "managedBy": {
                    "type": "string"
                },
                "partOf": {
                    "type": "string"
                },
                "technology": {
                    "type": "string"
                }
            }
        },
        "booleanOrString": {
            "anyOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "string"
                }
            ]
        }
    }
}
