        "HPA_SCALING_UP_INTERVAL": {
            "type": "integer"
        },
        "HPA_SCALING_DOWN_PERCENT": {
            "type": "integer"
        },
        "HPA_SCALING_DOWN_STABILIZATION_WINDOW_SECONDS": {
            "type": "integer"
        },
        "HPA_SCALING_DOWN_PERCENT_PERIOD_SECONDS": {
            "type": "integer"
